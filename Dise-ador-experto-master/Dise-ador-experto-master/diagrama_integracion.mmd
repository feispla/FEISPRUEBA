graph TD
    subgraph Frontend["Sitio Web FEISS (Frontend)"]
        A[Usuario visita la web] --> B{Acción del Usuario}
        B -- Realizar Compra --> C[Formulario de Pago Stripe]
        B -- Reservar Demo --> D[Calendario de Reservas]
        B -- Consultar Doc --> E[Sección de Documentación]
        B -- Contactar Soporte --> F[Formulario de Contacto]
    end

    subgraph Backend["Servidor FEISS (Node.js/Express)"]
        C --> G[Procesar Pago - Stripe API]
        D --> H[Gestionar Reserva]
        F --> I[Procesar Solicitud]
        E --> J[Consultar Contenido]
    end

    subgraph MCP_APIs["Integración de APIs MCP"]
        G -- Éxito --> K[Zapier: Automatización Post-Venta]
        G -- Éxito --> L[Gmail: Confirmación y Bienvenida]
        H --> M[Google Calendar: Crear Evento]
        I --> N[Gmail: Ticket de Soporte / Etiquetas]
        J --> O[Notion: Obtener Documentación Dinámica]
        K --> P[CRM / Mailchimp / Slack]
        N --> Q[Notion: Registro de Consultas]
    end

    subgraph Outcomes["Resultados / Beneficios"]
        L --> R[Experiencia de Usuario Mejorada]
        M --> S[Programación Automatizada]
        O --> T[Contenido Siempre Actualizado]
        P --> U[Flujo de Trabajo Optimizado]
    end

    style Frontend fill:#f9f,stroke:#333,stroke-width:2px
    style Backend fill:#bbf,stroke:#333,stroke-width:2px
    style MCP_APIs fill:#bfb,stroke:#333,stroke-width:2px
    style Outcomes fill:#fbf,stroke:#333,stroke-width:2px
