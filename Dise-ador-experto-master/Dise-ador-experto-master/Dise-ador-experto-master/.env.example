# ============================================
# CONFIGURACIÓN DE STRIPE
# ============================================
STRIPE_PUBLIC_KEY=pk_test_YOUR_STRIPE_PUBLIC_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ============================================
# CONFIGURACIÓN DE EMAIL (Fallback Nodemailer)
# ============================================
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# ============================================
# CONFIGURACIÓN DE SERVIDOR
# ============================================
PORT=3001
NODE_ENV=development
DOMAIN=http://localhost:3001
API_URL=http://localhost:3001

# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================
DATABASE_URL=mongodb://localhost:27017/feiss
DB_USER=admin
DB_PASSWORD=password

# ============================================
# INTEGRACIONES MCP - GMAIL
# ============================================
# Gmail MCP se configura automáticamente a través de manus-mcp-cli
# No requiere variables de entorno adicionales en el servidor
# La autenticación se maneja a través del MCP server

# ============================================
# INTEGRACIONES MCP - GOOGLE CALENDAR
# ============================================
# Google Calendar MCP se configura automáticamente a través de manus-mcp-cli
# No requiere variables de entorno adicionales en el servidor
# La autenticación se maneja a través del MCP server

# ============================================
# INTEGRACIONES MCP - NOTION
# ============================================
# Notion MCP se configura automáticamente a través de manus-mcp-cli
# Base de datos de soporte en Notion
NOTION_SUPPORT_DB_ID=your-notion-support-database-id
NOTION_DOCS_DB_ID=your-notion-docs-database-id

# ============================================
# INTEGRACIONES MCP - ZAPIER
# ============================================
# Zapier MCP se configura automáticamente a través de manus-mcp-cli
# URL del webhook de Zapier para automatizaciones
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_ZAPIER_ID/YOUR_ZAPIER_TOKEN

# ============================================
# CONFIGURACIÓN DE CLOUDFLARE
# ============================================
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
CLOUDFLARE_TURNSTILE_SITE_KEY=your-turnstile-site-key
CLOUDFLARE_TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ============================================
# CONFIGURACIÓN DE VERCEL
# ============================================
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_TOKEN=your-vercel-token

# ============================================
# CONFIGURACIÓN DE ANALYTICS
# ============================================
ENABLE_ANALYTICS=true
ANALYTICS_PROVIDER=cloudflare

# ============================================
# CONFIGURACIÓN DE SEGURIDAD
# ============================================
CORS_ORIGIN=*
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100
